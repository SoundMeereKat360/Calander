{
  "name": "ai-calendar-agent",
  "version": "1.0.0",
  "description": "AI-powered calendar agent for college scheduling and task management",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "build:azure": "npm run build --prefix client",
    "install-all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "axios": "1.6.8"
  },
  "devDependencies": {
    "nodemon": "^2.0.20"
  }
}
